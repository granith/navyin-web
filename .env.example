# Copy this file to `.env.local` (gitignored) and uncomment to force a country
# during local dev — handy since Vercel's real geo only runs on a deployment.
# Takes priority over edge geo and the session cache.
#
# Supported entries: us, gb, de, ch, dk, se, xk
# Aliases also work: at → de, li → de, al → xk
#
# VITE_COUNTRY=de
